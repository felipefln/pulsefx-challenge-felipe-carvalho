generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IndicatorSource {
  BCB
  FRED
}

enum IndicatorFrequency {
  DAILY
  MONTHLY
}

model Indicator {
  id             String             @id @default(cuid())
  code           String             @unique
  name           String
  description    String
  source         IndicatorSource
  sourceSeriesId String
  frequency      IndicatorFrequency
  unit           String?
  createdAt      DateTime           @default(now())

  observations Observation[]
  favorites    Favorite[]
  syncState    SyncState?

  @@map("indicators")
}

model Observation {
  id          String   @id @default(cuid())
  indicatorId String
  refDate     DateTime @db.Date
  value       Decimal  @db.Decimal(18, 6)
  createdAt   DateTime @default(now())

  indicator Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  @@unique([indicatorId, refDate])
  @@index([indicatorId, refDate])
  @@map("observations")
}

model Favorite {
  id              String   @id @default(cuid())
  anonymousUserId String
  indicatorId     String
  createdAt       DateTime @default(now())

  indicator Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  @@unique([anonymousUserId, indicatorId])
  @@map("favorites")
}

model SyncState {
  id           String    @id @default(cuid())
  indicatorId  String    @unique
  lastSyncedAt DateTime?
  lastRefDate  DateTime? @db.Date
  status       String    @default("idle")

  indicator Indicator @relation(fields: [indicatorId], references: [id], onDelete: Cascade)

  @@map("sync_state")
}
