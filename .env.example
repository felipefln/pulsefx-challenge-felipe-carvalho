# Usado pelo docker-compose.yml (serviço postgres)
POSTGRES_USER=pulsefx
POSTGRES_PASSWORD=pulsefx
POSTGRES_DB=pulsefx
# 5433 (não 5432) para não conflitar com um Postgres local já instalado na máquina
POSTGRES_PORT=5433

# Usado pelo docker-compose.yml (serviço api)
API_PORT=3333
# Registro/gestão da key em https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=
# Token exigido no header X-Admin-Token para acionar POST /admin/sync
ADMIN_SYNC_TOKEN=troque-por-um-valor-secreto
# Origens autorizadas a chamar a API via browser (CORS), separadas por vírgula
CORS_ORIGINS=http://localhost:5173

# Usado pelo docker-compose.yml (serviço web)
WEB_PORT=5173
# URL que o NAVEGADOR do usuário alcança (fica embutida no bundle em tempo de build)
VITE_API_URL=http://localhost:3333
